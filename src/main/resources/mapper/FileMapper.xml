<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gzasc.wechatappwaimai.mapper.FileMapper">

    <resultMap id="BaseResultMap" type="com.gzasc.wechatappwaimai.entity.UploadFile">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="original_name" property="originalName"/>
        <result column="save_path" property="savePath"/>
        <result column="size" property="size"/>
        <result column="create_time" property="createTime"/>
        <result column="entity_type" property="entityType"/>
        <result column="entity_id" property="entityId"/>
    </resultMap>

    <insert id="insert" parameterType="com.gzasc.wechatappwaimai.entity.UploadFile" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO file (user_id, original_name, save_path, size, create_time, entity_type, entity_id)
        VALUES (#{userId}, #{originalName}, #{savePath}, #{size}, #{createTime}, #{entityType}, #{entityId})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM file WHERE id = #{id}
    </select>

    <select id="selectByEntity" resultMap="BaseResultMap">
        SELECT * FROM file WHERE entity_type = #{entityType} AND entity_id = #{entityId}
    </select>

    <delete id="deleteById">
        DELETE FROM file WHERE id = #{id}
    </delete>

    <delete id="deleteByEntity">
        DELETE FROM file WHERE entity_type = #{entityType} AND entity_id = #{entityId}
    </delete>

</mapper>